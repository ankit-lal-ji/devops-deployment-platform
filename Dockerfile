# -------------------------------------------------
# Base Image
# -------------------------------------------------
FROM node:20-alpine

# -------------------------------------------------
# Working Directory
# -------------------------------------------------
WORKDIR /usr/src/app

# -------------------------------------------------
# Copy package files
# -------------------------------------------------
COPY app/package*.json ./

# -------------------------------------------------
# Install dependencies
# -------------------------------------------------
RUN npm install

# -------------------------------------------------
# Copy application source
# -------------------------------------------------
COPY app/ .

# -------------------------------------------------
# Expose application port
# -------------------------------------------------
EXPOSE 3000

# -------------------------------------------------
# Start application
# -------------------------------------------------
CMD ["npm", "start"]